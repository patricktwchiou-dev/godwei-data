        {
          "Id": 3,
          "Zh": "\u6C34\u4E0A\u904B\u52D5\u662F\u65BC\u6D77\u3001\u6E56\u3001\u6CB3\u7B49\u6C34\u57DF\u9032\u884C\u7684\u6D3B\u52D5\u7D71\u7A31\uFF0C\u5176\u4E2D\u6D6E\u6F5B\u3001\u6F5B\u6C34\u3001\u885D\u6D6A\u3001SUP\uFF08\u7ACB\u5F0F\u5212\u69F3\uFF09\u7B49\u9805\u76EE\u5EE3\u53D7\u6B61\u8FCE\u3002",
          "Ja": "\u30DE\u30EA\u30F3\u30B9\u30DD\u30FC\u30C4\u306F\u3001\u6D77\u30FB\u307F\u305A\u3046\u307F\u30FB\u5DDD\u306A\u3069\u306E\u6C34\u8FBA\u3067\u884C\u308F\u308C\u308B\u30A2\u30AF\u30C6\u30A3\u30D3\u30C6\u30A3\u306E\u7DCF\u79F0\u3067\n\u30B7\u30E5\u30CE\u30FC\u30B1\u30EA\u30F3\u30B0\u3001\u30C0\u30A4\u30D3\u30F3\u30B0\u3001\u30B5\u30FC\u30D5\u30A3\u30F3\u3001SUP\uFF08\u30B5\u30C3\u30D7\uFF09\u306A\u3069\u304C\u4EBA\u6C17\u3067\u3059",
